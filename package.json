{
  "name": "whatsapp-rag-backend",
  "version": "2.0.0",
  "main": "server-baileys.js",
  "scripts": {
    "start": "node server-baileys.js",
    "start:baileys": "node server-baileys.js",
    "dev": "nodemon server-baileys.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "keyv": "^4.5.4",
    "lru-cache": "^10.4.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "socks-proxy-agent": "^7.0.0",
    "sql.js": "^1.13.0",
    "@wppconnect-team/wppconnect": "^1.40.1",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "controllers/**/*.js",
      "routes/**/*.js",
      "middleware/**/*.js",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
